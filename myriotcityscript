-- 6. Helper Function To Design Navigation Sidebar Links
local function createNavigationTab(name, targetFrame)
	local tabBtn = Instance.new("TextButton")
	tabBtn.Size = UDim2.new(0, 130, 0, 36)
	tabBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 35)
	tabBtn.Text = name
	tabBtn.TextColor3 = Color3.fromRGB(200, 200, 210)
	tabBtn.TextSize = 13
	tabBtn.Font = Enum.Font.GothamSemibold
	tabBtn.Parent = TabButtonContainer

	local tabCorner = Instance.new("UICorner")
	tabCorner.CornerRadius = UDim.new(0, 6)
	tabCorner.Parent = tabBtn

	tabBtn.MouseButton1Click:Connect(function()
		MainTabFrame.Visible = false
		SettingsTabFrame.Visible = false
		targetFrame.Visible = true
	end)
end

createNavigationTab("Main", MainTabFrame)
createNavigationTab("Settings", SettingsTabFrame)

-- Helper Function to Build Standard Function Buttons
local function buildStandardButton(text)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 42)
	btn.BackgroundColor3 = Color3.fromRGB(35, 35, 42)
	btn.BorderSizePixel = 0
	btn.Text = "  " .. text
	btn.TextColor3 = Color3.fromRGB(235, 235, 240)
	btn.TextSize = 14
	btn.Font = Enum.Font.GothamSemibold
	btn.TextXAlignment = Enum.TextXAlignment.Left
	btn.Parent = MainTabFrame

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = btn
	
	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(55, 55, 65)
	stroke.Thickness = 1
	stroke.Parent = btn

	btn.MouseEnter:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55) end)
	btn.MouseLeave:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(35, 35, 42) end)
	return btn
end

