local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

-- ================= GUI (RGB COMMAND PANEL) =================
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "CommandPanel"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 220, 0, 200)
frame.Position = UDim2.new(0, 20, 0, 80)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.Text = "COMMAND PANEL"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1

-- RGB effect
spawn(function()
	while true do
		for i = 0,1,0.01 do
			frame.BorderColor3 = Color3.fromHSV(i,1,1)
			wait()
		end
	end
end)

-- Toggle Button
local toggle = Instance.new("TextButton", gui)
toggle.Size = UDim2.new(0,100,0,30)
toggle.Position = UDim2.new(0,20,0,20)
toggle.Text = "OPEN"

local open = true
toggle.MouseButton1Click:Connect(function()
	open = not open
	frame.Visible = open
end)

-- ================= BUTTONS =================
local function button(txt, y)
	local b = Instance.new("TextButton", frame)
	b.Size = UDim2.new(1,-20,0,30)
	b.Position = UDim2.new(0,10,0,y)
	b.Text = txt
	return b
end

local flyBtn = button("Fly: OFF",40)
local noclipBtn = button("Noclip: OFF",80)
local espBtn = button("ESP: OFF",120)

-- ================= FLY (PC + MOBILE) =================
local flying = false
local velocity

local function getMoveDirection()
	local move = Vector3.zero

	-- PC
	if UIS:IsKeyDown(Enum.KeyCode.W) then move += workspace.CurrentCamera.CFrame.LookVector end
	if UIS:IsKeyDown(Enum.KeyCode.S) then move -= workspace.CurrentCamera.CFrame.LookVector end

	-- Mobile joystick support
	if player.Character and player.Character:FindFirstChild("Humanoid") then
		move += player.Character.Humanoid.MoveDirection
	end

	return move
end

flyBtn.MouseButton1Click:Connect(function()
	flying = not flying
	flyBtn.Text = "Fly: " .. (flying and "ON" or "OFF")

	if flying then
		velocity = Instance.new("BodyVelocity")
		velocity.MaxForce = Vector3.new(1e5,1e5,1e5)
		velocity.Parent = char:WaitForChild("HumanoidRootPart")

		RunService.RenderStepped:Connect(function()
			if flying then
				velocity.Velocity = getMoveDirection() * 60
			end
		end)
	else
		if velocity then velocity:Destroy() end
	end
end)

-- ================= NOCLIP =================
local noclip = false

RunService.Stepped:Connect(function()
	if noclip and char then
		for _,v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

noclipBtn.MouseButton1Click:Connect(function()
	noclip = not noclip
	noclipBtn.Text = "Noclip: " .. (noclip and "ON" or "OFF")
end)

-- ================= ESP (FULL BODY + LINE) =================
local espEnabled = false
local espFolder = Instance.new("Folder", workspace)

local function getColor(team)
	if team == "Criminal" then
		return Color3.fromRGB(255,0,0)
	elseif team == "Cops" then
		return Color3.fromRGB(0,0,255)
	elseif team == "Inmate" then
		return Color3.fromRGB(255,165,0)
	else
		return Color3.fromRGB(255,255,255)
	end
end

local function createESP(p)
	if p == player then return end

	local function apply(char)
		-- FULL BODY HIGHLIGHT
		local highlight = Instance.new("Highlight")
		highlight.FillTransparency = 0.5
		highlight.OutlineColor = getColor(p.Team and p.Team.Name or "")
		highlight.Parent = char

		-- LINE ESP (Tracer)
		local beamPart0 = Instance.new("Attachment", player.Character.HumanoidRootPart)
		local beamPart1 = Instance.new("Attachment", char.HumanoidRootPart)

		local beam = Instance.new("Beam")
		beam.Attachment0 = beamPart0
		beam.Attachment1 = beamPart1
		beam.Color = ColorSequence.new(getColor(p.Team and p.Team.Name or ""))
		beam.Width0 = 0.1
		beam.Width1 = 0.1
		beam.Parent = char
	end

	if p.Character then
		apply(p.Character)
	end

	p.CharacterAdded:Connect(apply)
end

espBtn.MouseButton1Click:Connect(function()
	espEnabled = not espEnabled
	espBtn.Text = "ESP: " .. (espEnabled and "ON" or "OFF")

	espFolder:ClearAllChildren()

	if espEnabled then
		for _,p in pairs(Players:GetPlayers()) do
			createESP(p)
		end
	end
end)

Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function()
		if espEnabled then
			task.wait(1)
			createESP(p)
		end
	end)
end)
