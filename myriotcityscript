local function CreateFunctionButton(name, callback)
	local ButtonFrame = Instance.new("TextButton")
	ButtonFrame.Size = UDim2.new(1, -10, 0, 40)
	ButtonFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 42)
	ButtonFrame.BorderSizePixel = 0
	ButtonFrame.Text = "  " .. name
	ButtonFrame.TextColor3 = Color3.fromRGB(235, 235, 240)
	ButtonFrame.TextSize = 14
	ButtonFrame.Font = Enum.Font.GothamSemibold
	ButtonFrame.TextXAlignment = Enum.TextXAlignment.Left
	ButtonFrame.Parent = FunctionsContainer

	local BtnCorner = Instance.new("UICorner")
	BtnCorner.CornerRadius = UDim.new(0, 6)
	BtnCorner.Parent = ButtonFrame
	
	local BtnStroke = Instance.new("UIStroke")
	BtnStroke.Color = Color3.fromRGB(55, 55, 65)
	BtnStroke.Thickness = 1
	BtnStroke.Parent = ButtonFrame

	ButtonFrame.MouseEnter:Connect(function() ButtonFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 55) end)
	ButtonFrame.MouseLeave:Connect(function() ButtonFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 42) end)
	ButtonFrame.MouseButton1Click:Connect(callback)
end

